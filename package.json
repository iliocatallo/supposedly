{
  "name": "supposedly",
  "description": "A library to coerce values at run-time.",
  "version": "6.0.2",
  "author": "Ilio Catallo <info@iliocatallo.it>",
  "license": "MIT",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "files": [
    "/dist"
  ],
  "scripts": {
    "pretest": "npm run ts:check",
    "test": "c8 node -r tsm --test src/**.test.ts",
    "build": "tsc --build tsconfig.build.json",
    "ts:check": "tsc --noEmit",
    "prepare": "husky install",
    "dep:upgrade:major": "npx npm-check-updates -u",
    "dep:upgrade:minor": "npm run dep:upgrade:major -- --target minor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iliocatallo/supposedly.git"
  },
  "keywords": [
    "data",
    "typescript",
    "schema",
    "runtime",
    "external",
    "coercion",
    "coerce",
    "type-inference"
  ],
  "bugs": {
    "url": "https://github.com/iliocatallo/supposedly/issues"
  },
  "homepage": "https://github.com/iliocatallo/supposedly#readme",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "c8": "^11.0.0",
    "fast-check": "^3.13.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3",
    "tsm": "^2.3.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,css,md}": "prettier --write"
  },
  "engines": {
    "node": ">= 18.18.2"
  }
}
